.venv/
venv/
.venv-base-build/
__pycache__/
*.pyc
*.pyo
.models/
*.egg-info/
dist/
build/

# Windows packaging build outputs — install/windows/dist and
# install/windows/build are already caught by dist/ and build/ above; the
# zipped/compiled installer artifacts are not.
install/windows/portable/*.zip
install/windows/exe/*.exe

# Test / runner artifacts
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/
perf_results*.json

# Intermediate generated audio (written before WAV/MP3 export)
.generated/

# Per-session log files (structured text + telemetry JSONL)
# Format: session-<unix_ms>_AlienVox.{log,jsonl}  — mirrors Rust convention
.logs/
.telemetry/

# Telemetry test sinks
*.jsonl

# Runtime detection cache (written next to stacks.yaml on first run)
# The committed template is platform.yaml.example — copy it to platform.yaml to pre-populate.
platform.yaml

# User settings — instant-persisted next to the app (config.user_yaml_path()),
# not %LOCALAPPDATA% — this is per-user runtime state, never committed.
user.yaml
